{
    "style": {
        "foreground": "#ffffff",
        "background": "rgba(0, 0, 0, 0.5)",
        "borderradius": "10px",
        "shadowstrength": "10px",
        "answerbarwidth": "90%",
        "searchwidth": "90%",
        "expandability": "0%"
    },
    "window": {
        "width": 800,
        "height": 200
    },
    "summon": {
        "summon-on-mouse": true,
        "change-screen": true,
        "vertical-offset": 50
    },
    "tool-declorable": true,
    "tool-decloration-char": "@",
    "search-files": {
        "enabled": true,
        "starting-dirs": {
            "desktop": true,
            "documents": true,
            "downloads": true,
            "pictures": true,
            "music": true,
            "videos": true
        },
        "invalid-file-extensions": [
            ".gitignore",
            ".git",
            ".DS_Store"
        ],
        "invalid-directories": [
            "node_modules"
        ],
        "initial-max-depth": 3
    },
    "defult-extention": "wiki-search"
}