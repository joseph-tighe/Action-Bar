{
    "style": {
        "foreground": "#ffffff",
        "background": "rgba(0, 0, 0, 0.5)",
        "borderradius": "10px",
        "shadowstrength": "10px",
        "answerbarwidth": "90%",
        "searchwidth": "90%",
        "expandability": "0%",
        "tips": true
    },
    "window": {
        "width": 800,
        "height": 500
    },
    "summon": {
        "summon-on-mouse": false,
        "change-screen": true,
        "vertical-offset": 50
    },
    "tool-decloration": {
        "tool-declorable": true,
        "tool-decloration-char": "@"
    },
    "search-files": {
        "enabled": true,
        "starting-dirs": {
            "desktop": true,
            "documents": true,
            "downloads": true,
            "pictures": true,
            "music": true,
            "videos": true
        },
        "invalid-file-extensions": [
            ".gitignore",
            ".git",
            ".DS_Store"
        ],
        "invalid-directories": [
            "node_modules"
        ],
        "initial-max-depth": 3
    },
    "shortcuts": {
        "open-shortcut": "Alt+Z"
    },
    "extensions": {
        "defult-extentions": [
            "open",
            "ddg"
        ]
    },
    "pipelines": {
        "enabled": true,
        "noting-char": "#"
    },
    "answers": {
        "max-amount": 3
    },
    "aliases": {
        "enabled": true,
        "aliases-char": "/",
        "aliases": {
            "codex": "chatGPT",
            "VScode": "Visual Studio Code",
            "Google": "Google Chrome"
        }
    }
}