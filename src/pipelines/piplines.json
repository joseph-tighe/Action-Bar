[
    {
        "id": "get-hash",
        "name": "get-hash",
        "trigger": "with open",
        "input": "search",
        "output": "answer",
        "enabled":false,
        "steps": [
            {
                "id": "file",
                "action": "open",
                "inputs": [{"step": "input"}]
            },
            {
                "id": "command",
                "action": "join",
                "inputs": [
                    "certutil -hashfile \"",
                    {"step": "file"},
                    "\" SHA256"
                ]
            },
            {
                "id": "hash",
                "action": "bash",
                "inputs": [
                   { "step": "command" }
                ]
            },
            {
                "id": "output",
                "action": "output",
                "inputs": [
                    {"step": "hash"}
                ]
            }
        ]
    },
    {
        "id": "clipboard-math",
        "name": "clipboard math",
        "trigger": "call",
        "input": "clipboard",
        "output": "clipboard",
        "enabled":true,
        "steps": [
            {
                "id": "calculator",
                "action": "calculator",
                "inputs": [{"step": "input"}]  
            },
            {
                "id": "output",
                "action": "output",
                "inputs": [
                    {"step": "calculator"}
                ]
            }
        ]
    }
]